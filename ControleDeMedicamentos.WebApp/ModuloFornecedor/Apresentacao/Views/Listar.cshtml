@{
    ViewBag.Titulo = "Listagem de Fornecedores";
}

@model List<FornecedorViewModel>;

<partial name="_BotaoCadastrar" />

@if (TempData["MensagemErro"] is string mensagemErro)
{
    <partial name="_Alerta" model="@new AlertaViewModel(mensagemErro, true)" />
}
@if (Model.Count == 0)
{
    <partial name="_Alerta" model="@(new AlertaViewModel("Nenhum fornecedor cadastrado."))" />
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-2">
        @foreach (FornecedorViewModel f in Model)
        {
            var campos = new[] {
                f.DisplayField(vm => vm.Telefone),
                f.DisplayField(vm => vm.CNPJ, "CNPJ"),
                f.DisplayField(vm => vm.Medicamentos, "Medicamentos")
            };
            <partial name="_Card" model="(f.DisplayField(vm => vm.Id.ToShortString(), f.Nome), campos, f.Id, false)" />
        }
    </div>
}
