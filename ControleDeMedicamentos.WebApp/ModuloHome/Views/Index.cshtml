@{
    ViewBag.Titulo = "Página Inicial";
}

<div class="row">
    <div class="col-lg-7">
        <h1 class="display-5 fw-semibold mb-3">Controle de Medicamentos</h1>
        <p class="lead text-secondary mb-4">
            Gerencie fornecedores, medicamentos, pacientes, funcionários e estoque em uma aplicação simples para manter controle sobre os medicamentos.
        </p>

        @* <a class="btn btn-primary rounded-pill px-4" asp-controller="(*)" asp-action="Listar">Acessar (*)s</a> *@
        <a class="btn btn-primary rounded-pill px-4" asp-controller="Fornecedor" asp-action="Listar">Acessar Fornecedores</a>
        <a class="btn btn-primary rounded-pill px-4" asp-controller="Medicamento" asp-action="Listar">Acessar Medicamentos</a>
        <a class="btn btn-primary rounded-pill px-4" asp-controller="Paciente" asp-action="Listar">Acessar Pacientes</a>
        <a class="btn btn-primary rounded-pill px-4" asp-controller="Funcionario" asp-action="Listar">Acessar Funcionários</a>

    </div>

    <div class="col-lg-5">
        <div class="card border-primary-subtle shadow-sm">
            <div class="card-body p-4">
                <h3 class="h5 text-primary mb-3">Módulos disponíveis</h3>

                @*
                <div class="list-group">
                    <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" asp-controller="(*)" asp-action="Listar">
                        Controle de (*)s
                        <span class="badge text-bg-primary rounded-pill">Abrir</span>
                    </a>
                </div>
                *@
                <div class="list-group">
                    <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" asp-controller="Fornecedor" asp-action="Listar">
                        Controle de Fornecedores
                        <span class="badge text-bg-primary rounded-pill">Abrir</span>
                    </a>
                </div>
                <div class="list-group">
                    <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" asp-controller="Medicamento" asp-action="Listar">
                        Controle de Medicamentos
                        <span class="badge text-bg-primary rounded-pill">Abrir</span>
                    </a>
                </div>
                <div class="list-group">
                    <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" asp-controller="Paciente" asp-action="Listar">
                        Controle de Pacientes
                        <span class="badge text-bg-primary rounded-pill">Abrir</span>
                    </a>
                </div>
                <div class="list-group">
                    <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" asp-controller="Funcionario" asp-action="Listar">
                        Controle de Funcionários
                        <span class="badge text-bg-primary rounded-pill">Abrir</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
