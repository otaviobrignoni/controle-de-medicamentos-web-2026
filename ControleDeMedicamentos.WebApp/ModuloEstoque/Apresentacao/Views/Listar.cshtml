@{
    ViewBag.Titulo = "Listagem de Requisições";
}

@model (List<MostrarEntradaViewModel> entradas, List<MostrarSaidaViewModel> saidas)

<partial name="_BotaoCadastrar" />

@if (TempData["MensagemErro"] is string mensagemErro)
{
    <partial name="_Alerta" model="@new AlertaViewModel(mensagemErro, true)" />
}

@if (Model.entradas.Count == 0 && Model.saidas.Count == 0)
{
    <partial name="_Alerta" model="@(new AlertaViewModel("Nenhuma requisição cadastrada."))" />
}
else
{
    <div class="row g-4">
        <section class="col-12 col-lg-6">
            <h3 class="mb-3">Entradas</h3>

            <div class="card border-primary-subtle shadow-sm">
                <div class="card-body">
                    @if (Model.entradas.Count == 0)
                    {
                        <partial name="_Alerta" model="@(new AlertaViewModel("Nenhuma requisição de entrada cadastrada."))" />
                    }
                    else
                    {
                        <div class="vstack gap-3">
                            @foreach (var re in Model.entradas)
                            {
                                var campos = new[] {
                                    re.DisplayField(vm => vm.Medicamento),
                                    re.DisplayField(vm => vm.Quantidade),
                                    re.DisplayField(vm => vm.Funcionario, "Funcionário")
                                };
                                <div class="card">
                                    <div class="card-body">
                                        <partial name="_CardTitulo" model="@re.DisplayField(vm => vm.Id.ToShortString(), $"Entrada {re.Data:dd/MM/yyyy}")" />
                                        <partial name="_CardCampos" model="@campos" />
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </section>

        <section class="col-12 col-lg-6">
            <h3 class="mb-3">Saídas</h3>

            <div class="card border-primary-subtle shadow-sm">
                <div class="card-body">
                    @if (Model.saidas.Count == 0)
                    {
                        <partial name="_Alerta" model="@(new AlertaViewModel("Nenhuma requisição de saída cadastrada."))" />
                    }
                    else
                    {
                        <div class="vstack gap-3">
                            @foreach (var rs in Model.saidas)
                            {
                                var itensHtml = new HtmlString(string.Join("<br>", rs.Itens.Select(i => $"{i.Quantidade} × {i.Medicamento}")));
                                var campos = new[] {
                                    rs.DisplayField(vm => vm.Paciente),
                                    rs.DisplayField(vm => vm.Itens, itensHtml, "Medicamentos")
                                };
                                <div class="card">
                                    <div class="card-body">
                                        <partial name="_CardTitulo" model="@rs.DisplayField(vm => vm.Id.ToShortString(), $"Saída {rs.Data:dd/MM/yyyy}")" />
                                        <partial name="_CardCampos" model="@campos" />
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </section>
    </div>
}
