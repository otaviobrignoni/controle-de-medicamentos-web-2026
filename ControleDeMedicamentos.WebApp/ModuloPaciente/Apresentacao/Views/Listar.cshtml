@{
    ViewBag.Titulo = "Listagem de Pacientes";
}

@model List<PacienteViewModel>;

<partial name="_BotaoCadastrar" />

@if (TempData["MensagemErro"] is string mensagemErro)
{
    <partial name="_Alerta" model="@new AlertaViewModel(mensagemErro, true)" />
}
@if (Model.Count == 0)
{
    <partial name="_Alerta" model="@(new AlertaViewModel("Nenhum paciente cadastrado."))" />
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-2">
        @foreach (var p in Model)
        {
            var campos = new[] {
                p.DisplayField(vm => vm.Telefone),
                p.DisplayField(vm => vm.CartaoSUS, "Cartão do SUS"),
                p.DisplayField(vm => vm.CPF, "CPF")
            };
            <partial name="_Card" model="(p.DisplayField(vm => vm.Id.ToShortString(), p.Nome), campos, p.Id, false)" />
        }
    </div>
}
