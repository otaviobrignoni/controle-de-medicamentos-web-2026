@{
    ViewBag.Titulo = string.Empty;
}

@model MedicamentoMostrarViewModel;

<div class="card border-primary-subtle shadow-sm mx-auto p-4" style="">
    <h2 class="fw-bold mb-4 text-uppercase" style="color:#495057">@Model.Nome</h2>
    <dl class="row mb-0">
        <dt class="col-sm-4 fw-semibold text-primary text-uppercase small">ID</dt>
        <dd class="col-sm-8">@Model.Id</dd>

        <dt class="col-sm-4 fw-semibold text-primary text-uppercase small">Descrição</dt>
        <dd class="col-sm-8">@Model.Descricao</dd>

        <dt class="col-sm-4 fw-semibold text-primary text-uppercase small">Quantidade de Itens</dt>
        <dd class="col-sm-8">@Model.Quantidade</dd>

        <dt class="col-sm-4 fw-semibold text-primary text-uppercase small">Fornecedor</dt>
        <dd class="col-sm-8">@Model.FornecedorNome.Capitalizar()</dd>
    </dl>

    <div class="d-flex justify-content-end gap-2 mt-4">
        <a class="btn btn-outline-primary rounded-pill px-4" asp-action="Listar">Voltar</a>
    </div>
</div>
        

                