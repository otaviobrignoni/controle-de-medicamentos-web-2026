@{
    ViewBag.Titulo = "Exclusão de Medicamento";
    var campos = new[] {
        Model.DisplayField(vm => vm.Id, "ID"),
        Model.DisplayField(vm => vm.Nome),
        Model.DisplayField(vm => vm.Descricao, "Descrição"),
        Model.DisplayField(vm => vm.Quantidade, "Quantidade de Itens"),
        Model.DisplayField(vm => vm.FornecedorNome, "Fornecedor")
    };
}

@model MedicamentoMostrarViewModel;

<form class="card border-primary-subtle shadow-sm mx-auto p-4" style="max-width: 620px;" asp-action="Excluir" asp-route-id="@Model.Id" method="post">
    <partial name="_Alerta" model="@(new AlertaViewModel("Tem certeza que deseja excluir este medicamento?"))" />
    <partial name="_CardCampos" model="@campos" />
    <partial name="_FormAcoes" />
</form>

